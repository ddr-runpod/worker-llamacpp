# =============================================================================
# llama.cpp Worker Configuration
# Optimized for: RTX 5090 (32GB VRAM) + Gemma 4 26B A4B (UD-Q6_K_XL)
# Use case: Chat + Agentic mode
# =============================================================================

# -----------------------------------------------------------------------------
# Model Configuration (Required)
# -----------------------------------------------------------------------------

# HuggingFace model ID in format: namespace/model:quantization
# UD-Q6_K_XL = ~23GB on disk, good quality balance for 32GB VRAM
# Alternative quantizations:
#   - UD-Q5_K_XL (~21GB): Slightly less quality, more VRAM headroom
#   - UD-Q4_K_XL (~17GB): Lower quality, more room for larger context
LLAMA_MODEL=unsloth/gemma-4-26B-A4B-it-GGUF:UD-Q6_K_XL

# -----------------------------------------------------------------------------
# HuggingFace Cache (Optional)
# -----------------------------------------------------------------------------

# Directory to cache HuggingFace models (use network volume for persistence)
# This avoids re-downloading the model on worker restarts
HF_HOME=/runpod-volume/huggingface-cache

# HuggingFace access token (required for gated models like Llama 4, etc.)
# Leave empty if not needed
HF_TOKEN=

# -----------------------------------------------------------------------------
# Sampling Configuration
# -----------------------------------------------------------------------------

# Context window size (in tokens)
# Maximum: Model supports 256K, but 32K+ uses significant VRAM for KV cache
# Recommended:
#   - 8192:  Fastest, minimal VRAM overhead
#   - 16384: Good balance for chat/agentic (default)
#   - 32768: Large context, more VRAM usage - may need to reduce batch size
LLAMA_CONTEXT_SIZE=16384

# Number of model layers to offload to GPU
# 99 (or -1, or any value >= model layers) = full GPU offload
# For Gemma 4 26B A4B: 30 layers total
# Full offload maximizes inference speed (10-50x faster than CPU)
LLAMA_N_GPU_LAYERS=99

# Sampling temperature (0.0 - 2.0)
# Controls randomness in output generation
# Recommended:
#   - 0.1-0.3: Very deterministic, best for tool calling / code
#   - 0.6-0.7: Good balance for chat + agentic reasoning (default)
#   - 0.8-1.0: More creative/varied output
LLAMA_TEMPERATURE=0.6

# Top-p sampling (nucleus sampling, 0.0 - 1.0)
# Limits token selection to cumulative probability threshold
# Lower = more restrictive, higher = more diverse
# 0.95 is standard for chat applications
LLAMA_TOP_P=0.95

# Top-k sampling
# Limits token selection to top k most likely tokens
# 64 is standard; lower values = more focused output
LLAMA_TOP_K=64

# Number of parallel request slots
# 1 = single request at a time (recommended for serverless)
# Higher values increase throughput but use more VRAM
LLAMA_N_PARALLEL=1

# -----------------------------------------------------------------------------
# Reasoning Configuration
# -----------------------------------------------------------------------------

# Enable/disable reasoning mode for supported models
# Accepted values: on, 1, yes, off, 0, no (case-insensitive)
LLAMA_REASONING=on

# -----------------------------------------------------------------------------
# Advanced Options
# -----------------------------------------------------------------------------

# CPU threads (uncomment to override)
# Default: auto-detected. Lower values when using GPU offload.
# LLAMA_THREADS=8

# Additional llama-server command-line arguments
# Format: space-separated flags, use quotes for args with spaces
#
# Flags explained:
#   --flash-attn      : Enable Flash Attention (1.2-1.5x speedup on RTX 5090)
#   --cont-batching   : Enable continuous batching for better throughput
#   -b 512            : Batch size for prompt processing
#   -ub 512           : Physical (unbatched) size for generation
#
# VRAM Considerations with 32GB:
#   - 512/512 batch sizes are safe with 16K context
#   - If using 32K context, reduce to -b 256 -ub 256 to avoid OOM
#   - If OOM errors occur, try -b 256 -ub 256 or reduce context size
LLAMA_EXTRA_ARGS="--flash-attn on --cont-batching -b 512 -ub 512"
